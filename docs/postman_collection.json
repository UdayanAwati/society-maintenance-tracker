{
  "info": {
    "name": "Society Maintenance Tracker",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080/api" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\"name\":\"Resident One\",\"email\":\"resident1@society.test\",\"password\":\"Password@123\",\"phone\":\"9999999999\",\"flatNumber\":\"C-502\"}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": { "mode": "raw", "raw": "{\"email\":\"admin@society.test\",\"password\":\"Password@123\"}" }
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/auth/me"
          }
        }
      ]
    },
    {
      "name": "Complaints",
      "item": [
        {
          "name": "Create Complaint",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/complaints",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "data", "type": "text", "value": "{\"category\":\"Plumbing\",\"description\":\"Bathroom drain is blocked.\"}" },
                { "key": "photo", "type": "file", "src": "" }
              ]
            }
          }
        },
        {
          "name": "List Admin Complaints",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/complaints?status=OPEN&priority=HIGH"
          }
        },
        {
          "name": "Update Complaint",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/complaints/1",
            "body": { "mode": "raw", "raw": "{\"status\":\"IN_PROGRESS\",\"priority\":\"HIGH\",\"note\":\"Assigned to maintenance team\"}" }
          }
        }
      ]
    },
    {
      "name": "Notices",
      "item": [
        {
          "name": "List Notices",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/notices"
          }
        },
        {
          "name": "Create Notice",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/notices",
            "body": { "mode": "raw", "raw": "{\"title\":\"Lift Maintenance\",\"description\":\"Tower A lift will be serviced tonight.\",\"important\":true}" }
          }
        }
      ]
    },
    {
      "name": "Dashboards",
      "item": [
        {
          "name": "Admin Dashboard",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/dashboard/admin"
          }
        },
        {
          "name": "Resident Dashboard",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/dashboard/resident"
          }
        }
      ]
    }
  ]
}
